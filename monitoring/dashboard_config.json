{
  "dashboard_name": "clash-etl-overview",
  "description": "Dashboard de observabilidade do pipeline ELT Clash Royale",
  "widgets": [
    {
      "type": "metric",
      "title": "EC2 - CPU Utilization",
      "namespace": "AWS/EC2",
      "metric_name": "CPUUtilization",
      "dimensions": { "InstanceId": "i-0c2ea81412f54844b" },
      "period_seconds": 300,
      "stat": "Average"
    },
    {
      "type": "metric",
      "title": "Glue Jobs - Execuções (Battles)",
      "namespace": "Glue",
      "metric_name": "glue.driver.aggregate.numCompletedTasks",
      "dimensions": { "JobName": "clashr_silver_battles" },
      "period_seconds": 3600,
      "stat": "Sum"
    },
    {
      "type": "metric",
      "title": "Glue Jobs - Execuções (Profile)",
      "namespace": "Glue",
      "metric_name": "glue.driver.aggregate.numCompletedTasks",
      "dimensions": { "JobName": "clashr_silver_profile" },
      "period_seconds": 3600,
      "stat": "Sum"
    },
    {
      "type": "metric",
      "title": "Glue Jobs - Falhas",
      "namespace": "Glue",
      "metric_name": "glue.driver.aggregate.numFailedTasks",
      "dimensions": { "JobName": "clashr_silver_battles" },
      "period_seconds": 3600,
      "stat": "Sum"
    },
    {
      "type": "metric",
      "title": "Lambda clash-glue-trigger - Invocações",
      "namespace": "AWS/Lambda",
      "metric_name": "Invocations",
      "dimensions": { "FunctionName": "clash-glue-trigger" },
      "period_seconds": 3600,
      "stat": "Sum"
    },
    {
      "type": "metric",
      "title": "Lambda clash-glue-trigger - Erros",
      "namespace": "AWS/Lambda",
      "metric_name": "Errors",
      "dimensions": { "FunctionName": "clash-glue-trigger" },
      "period_seconds": 3600,
      "stat": "Sum"
    },
    {
      "type": "metric",
      "title": "Lambda clash-glue-trigger - Duração",
      "namespace": "AWS/Lambda",
      "metric_name": "Duration",
      "dimensions": { "FunctionName": "clash-glue-trigger" },
      "period_seconds": 3600,
      "stat": "Average"
    }
  ],
  "setup_instructions": "Para criar este dashboard no Console: CloudWatch > Dashboards > Create dashboard > clash-etl-overview > adicionar cada widget acima manualmente, ou usar 'aws cloudwatch put-dashboard' com este JSON convertido para o formato de DashboardBody esperado pela API."
}